# ============================================================
# Ashiana backend environment variables
# Copy this file to ".env" and fill in real values before
# running on a server. On Render / Railway / Fly etc., paste
# each KEY=VALUE pair into the platform's Environment screen.
# ============================================================

# Port the server listens on. Most hosts set this for you.
PORT=3000

# 32+ random characters. Used to sign admin session cookies.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=please_replace_with_a_long_random_string_at_least_32_chars

# First-run admin credentials. After first login, change the
# password via the dashboard, then you can remove these lines.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# SQLite database file path. Default sits next to server.js.
# On Render / Fly use a persistent disk mount (e.g. /data/ashiana.db).
DB_PATH=./ashiana.db

# Comma-separated list of frontend origins allowed to POST submissions.
# Example for the existing preview:
#   ALLOWED_ORIGINS=https://fabulous-pasca-6ca3c4.netlify.app
# For the production domain:
#   ALLOWED_ORIGINS=https://www.ashianasheffield.org,https://ashianasheffield.org
# Leave empty to allow all origins (development only).
ALLOWED_ORIGINS=

NODE_ENV=production
